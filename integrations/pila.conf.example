# ============================================================
# PILA Suite — Integration Configuration
# Copy this file to pila.conf and fill in your values.
# NEVER commit pila.conf to git — it contains credentials.
# ============================================================

[api]
# Master API key — generate a strong random key
# Run: python3 -c "import secrets; print('pila-' + secrets.token_urlsafe(32))"
api_key      = YOUR_MASTER_API_KEY_HERE
require_auth = true

[license]
# License API URL — leave as default unless running license server elsewhere
api_url = http://127.0.0.1:8001

[elasticsearch]
# Your Elasticsearch instance
host       = YOUR_ELASTICSEARCH_IP
port       = 9200
username   = elastic
password   = YOUR_ELASTIC_PASSWORD
scheme     = https
verify_ssl = false

# Index patterns — adjust to match your Filebeat/ECS setup
alert_indices            = filebeat-*
suricata_index           = filebeat-*
zeek_index               = filebeat-*
packetbeat_index         = packetbeat-*
detection_window_seconds = 86400

[suricata]
# Optional: direct SSH access to Suricata host for rule management
host     = YOUR_SURICATA_HOST_IP
eve_path = /var/log/suricata/eve.json
ssh_user =
ssh_key  = ~/.ssh/id_rsa

[zeek]
# Optional: Zeek log path
host     = YOUR_ZEEK_HOST_IP
log_path = /var/log/zeek/

[observer]
# CODE Suite — OBSERVER module API keys (Professional Edition)
# AbuseIPDB: https://www.abuseipdb.com/account/api
# VirusTotal: https://www.virustotal.com/gui/my-apikey
abuseipdb_key  = YOUR_ABUSEIPDB_KEY_HERE
virustotal_key = YOUR_VIRUSTOTAL_KEY_HERE
